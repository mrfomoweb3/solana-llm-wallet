# Solana LLM Wallet Agent — Environment Variables

# Required: Your Groq API key
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Required for Telegram bot: Bot token from @BotFather
# Get one at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Optional: Default Solana network (devnet or mainnet-beta)
# Users can override this per-session via /network command
SOLANA_NETWORK=devnet

# Optional: Set to "true" to see verbose output (LLM prompts, full audit entries)
VERBOSE=false

# Required: Jupiter API key (free from https://portal.jup.ag)
JUPITER_API_KEY=your-jupiter-api-key-here
